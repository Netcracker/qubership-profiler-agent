# The default set of validations is listed in https://github.com/Netcracker/.github/blob/main/config/linters/super-linter.env
# If you need to activate a linter that is disabled by default, add it with an empty value as follows:
# VALIDATE_JSCPD=
JAVA_FILE_NAME=checkstyle.xml
# Workaround for https://github.com/Netcracker/qubership-workflow-hub/issues/447
VALIDATE_BIOME_FORMAT=false
VALIDATE_BIOME_LINT=false
# Enable CGO for Go linting (required for jattach library)
CGO_ENABLED=1
# Exclude backend/ and it-e2e/ from linting until pre-existing issues are resolved.
# it-e2e holds Playwright TypeScript specs; super-linter's default ESLint config references
# eslint-plugin-n, which is absent from its image, so any linted TS outside these excludes fails.
FILTER_REGEX_EXCLUDE=backend/.*|it-e2e/.*|(^|/)(\.agents/|\.codex/|\.claude/(apm-hooks\.json|settings\.json|rules/|skills/)|\.cursor/(hooks\.json|rules/))
