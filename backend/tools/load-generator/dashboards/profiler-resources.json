{
  "uid": "profiler-resources",
  "title": "Profiler load / Resources",
  "description": "CPU / RAM / disk / network / S3 resource curves (load-testing-plan.md \u00a76.2: resources; goals a, b).",
  "tags": [
    "profiler-load-stand"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "refresh": 1
      },
      {
        "name": "namespace",
        "label": "namespace",
        "type": "textbox",
        "query": "profiler-load",
        "current": {
          "text": "profiler-load",
          "value": "profiler-load"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU by pod",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "cAdvisor via the kubelet ServiceMonitor.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "cores"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", container!=\"\", pod!=\"\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "id": 1
    },
