{
  "uid": "profiler-backpressure",
  "title": "Profiler load / Backpressure",
  "description": "Backpressure chain of the collector (load-testing-plan.md \u00a76.2: backpressure; \u00a77 T7 expected chain).",
  "tags": [
    "profiler-load-stand"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "refresh": 1
      },
      {
        "name": "namespace",
        "label": "namespace",
        "type": "textbox",
        "query": "profiler-load",
        "current": {
          "text": "profiler-load",
          "value": "profiler-load"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Backpressure gates (1 = paused)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Seal pauses at half the pending-upload budget, ingest at the full budget (01 \u00a74.6).",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "short",
          "max": 1,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "profiler_backpressure_seal_paused{namespace=\"$namespace\"}",
          "legendFormat": "seal {{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "profiler_backpressure_ingest_paused{namespace=\"$namespace\"}",
          "legendFormat": "ingest {{pod}}",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "id": 1
    },
    {
      "type": "timeseries",
      "title": "Pending-upload backlog vs budget",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "The three gate components; ingest refuses data once their sum reaches the budget.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (pod) (profiler_hotstore_pending_parquet_bytes{namespace=\"$namespace\"})",
          "legendFormat": "parquet {{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "sum by (pod) (profiler_hotstore_partitions_disk_bytes{namespace=\"$namespace\"})",
          "legendFormat": "partitions {{pod}}",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "sum by (pod) (profiler_hotstore_wal_disk_bytes{namespace=\"$namespace\"})",
          "legendFormat": "wal {{pod}}",
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "max(profiler_hotstore_pending_budget_bytes{namespace=\"$namespace\"})",
          "legendFormat": "budget",
          "refId": "D",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "id": 2
    },
    {
      "type": "timeseries",
      "title": "Seal queue depth",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Pod-restart buckets waiting to seal; grows while backpressure pauses sealing.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "profiler_seal_queue_depth{namespace=\"$namespace\"}",
          "legendFormat": "{{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "id": 3
    },
    {
      "type": "timeseries",
      "title": "Refused bytes/s",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (pod) (rate(profiler_ingest_refused_bytes_total{namespace=\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "Segment disk usage vs budget",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "profiler_hotstore_segments_disk_bytes{namespace=\"$namespace\"}",
          "legendFormat": "used {{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "max(profiler_hotstore_segments_disk_budget_bytes{namespace=\"$namespace\"})",
          "legendFormat": "budget",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "In-RAM state vs mem budget",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "profiler_hotstore_inram_bytes{namespace=\"$namespace\"}",
          "legendFormat": "in-RAM {{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "max(profiler_hotstore_mem_budget_bytes{namespace=\"$namespace\"})",
          "legendFormat": "budget",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "id": 6
    }
  ],
  "editable": true
}
