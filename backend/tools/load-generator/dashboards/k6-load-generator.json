{
  "uid": "k6-load-generator",
  "title": "Profiler load / k6 generator",
  "description": "k6 fleet (k6/x/cdt over the virtual dumper) series pushed over Prometheus remote write (load-testing-plan.md §6.2: k6).",
  "tags": [
    "profiler-load-stand"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "refresh": 1
      },
      {
        "name": "namespace",
        "label": "namespace",
        "type": "textbox",
        "query": "profiler-load",
        "current": {
          "text": "profiler-load",
          "value": "profiler-load"
        }
      },
      {
        "name": "testid",
        "label": "testid (run label)",
        "type": "textbox",
        "query": ".*",
        "current": {
          "text": ".*",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Sent bytes/s by stream",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Generator-side view of the ingest load, per contract stream (~6 MB/s cluster total for T1).",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (stream) (rate(k6_vdumper_sent_bytes_total{testid=~\"$testid\"}[$__rate_interval]))",
          "legendFormat": "{{stream}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "sum(rate(k6_vdumper_sent_bytes_total{testid=~\"$testid\"}[$__rate_interval]))",
          "legendFormat": "total",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "id": 1
    },
    {
      "type": "timeseries",
      "title": "Virtual users (fleets)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "One VU holds PODS_PER_VU virtual dumpers; the run orchestrator scales VUs over the k6 REST API.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "k6_vus",
          "legendFormat": "VUs",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "id": 2
    },
    {
      "type": "timeseries",
      "title": "Fleet lifecycle/s",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Connects are completed session setups; reconnects are dead incarnations entering the agent's 10 s restart path; churns are deliberate churn-mode cycles (T5 storms).",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "rate(k6_vdumper_connects_total{testid=~\"$testid\"}[$__rate_interval])",
          "legendFormat": "connects",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "rate(k6_vdumper_reconnects_total{testid=~\"$testid\"}[$__rate_interval])",
          "legendFormat": "reconnects",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "rate(k6_vdumper_churns_total{testid=~\"$testid\"}[$__rate_interval])",
          "legendFormat": "churns",
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "id": 3
    },
    {
      "type": "timeseries",
      "title": "Backpressure and losses/s",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Ack errors are ACK_ERROR_MAGIC refusals (collector backpressure); dropped chunks are producer buffers lost in reconnect drop windows. Both are T2 saturation signals.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "rate(k6_vdumper_ack_errors_total{testid=~\"$testid\"}[$__rate_interval])",
          "legendFormat": "ack errors",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "rate(k6_vdumper_dropped_chunks_total{testid=~\"$testid\"}[$__rate_interval])",
          "legendFormat": "dropped chunks",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "Ack flush time (T2 signal)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Per-stream synchronous ack drain inside the regular 5 s flush cycle; a rising p95 against the first-step baseline is the ack-path degradation detector.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "k6_vdumper_ack_flush_time_avg{testid=~\"$testid\"}",
          "legendFormat": "avg",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "k6_vdumper_ack_flush_time_p95{testid=~\"$testid\"}",
          "legendFormat": "p95",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "Session ready / TCP connect (T3 signal)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Session ready spans dial start to all seven streams open; TCP connect is the dial alone. Divergence points at the handshake/stream-setup path, not the accept queue.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "k6_vdumper_session_ready_time_p95{testid=~\"$testid\"}",
          "legendFormat": "session ready p95",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "k6_vdumper_session_ready_time_avg{testid=~\"$testid\"}",
          "legendFormat": "session ready avg",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "k6_vdumper_tcp_connect_time_p95{testid=~\"$testid\"}",
          "legendFormat": "tcp connect p95",
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "id": 6
    },
    {
      "type": "timeseries",
      "title": "Generator CPU / RSS",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "The generator must not become the bottleneck being measured (plan §10); the runner marks a step invalid when the k6 pod runs over 70% of its CPU limit.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"cdt-loader.*\", container!=\"\"}[$__rate_interval]))",
          "legendFormat": "cpu {{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "container_memory_working_set_bytes{namespace=\"$namespace\", pod=~\"cdt-loader.*\", container!=\"\"}",
          "legendFormat": "rss {{pod}}",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "go_goroutines{namespace=\"$namespace\", pod=~\"cdt-loader.*\"}",
          "legendFormat": "goroutines {{pod}}",
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "id": 7
    }
  ],
  "editable": true
}